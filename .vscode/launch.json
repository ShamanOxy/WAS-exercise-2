  "inputs": [
    {
      "id": "searchAlgorithm",
      "description": "Search algorithm",
      "type": "pickString",
      "options": ["bfs", "astar", "wastar", "gbf", "ehs", "ids", "sat"],
      "default": "bfs"
    },
    {
      "id": "domainFile",
      "description": "Path to domain PDDL file",
      "type": "promptString",
      "default": "task-2/examples/blocks-world-domain.pddl"
    },
    {
      "id": "problemFile",
      "description": "Path to problem PDDL file",
      "type": "promptString",
      "default": "task-2/examples/blocks-world-problem.pddl"
    }
  ]
